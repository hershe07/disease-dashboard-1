# ── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chronic_illness_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── WHO GHO API ────────────────────────────────────────────
WHO_GHO_BASE_URL=https://ghoapi.azureedge.net/api

# ── CDC (Socrata) ──────────────────────────────────────────
CDC_APP_TOKEN=your_cdc_app_token
CDC_CDI_ENDPOINT=https://data.cdc.gov/resource/g4ie-h725.json
CDC_BRFSS_ENDPOINT=https://data.cdc.gov/resource/dttw-5yxu.json

# ── World Bank ─────────────────────────────────────────────
WORLDBANK_API_BASE=https://api.worldbank.org/v2

# ── OpenAQ (real-time environment) ────────────────────────
OPENAQ_API_KEY=your_openaq_api_key
OPENAQ_BASE_URL=https://api.openaq.org/v3

# ── Validic (real-time wearables) ─────────────────────────
VALIDIC_ORG_ID=your_validic_org_id
VALIDIC_TOKEN=your_validic_token
VALIDIC_BASE_URL=https://app.validic.com/v1

# ── Pipeline ───────────────────────────────────────────────
LOG_LEVEL=INFO
